#
# General 
#
projectile p
element ni
mass 60
energy 1.012195122 15.18292683 1.012195122e-1
#
#select level density
ldmodel 1
outdensity y
filedensity y
#
#select strength
strength 1
strengthM1 1
outgamma y
filepsf y
#
# accuracy cutoffs
xseps 1.e-20
transeps 1.e-20
transpower 15
popeps 1.e-20
#
# increase number of bins and use equidistant spacing
bins 80
equidistant y
#
# switch preequilibrium off
preequilibrium no
